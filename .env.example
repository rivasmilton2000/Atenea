APP_ENV=local
APP_KEY=
# La aplicacion selecciona una sola base segun APP_ENV y genera el callback OAuth.
APP_URL_LOCAL=http://localhost/Atenea
APP_URL_PRODUCTION=
# Alias opcional compatible: APP_URL=https://dominio.example/Atenea

ATENEA_DB_HOST=localhost
ATENEA_DB_NAME=db_atenea
ATENEA_DB_USER=root
ATENEA_DB_PASSWORD=
ATENEA_ADMIN_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pagos Stripe. Use exclusivamente credenciales del entorno correspondiente.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Comercio. Se expresan como valores decimales; no incluya simbolos monetarios.
SHOP_SHIPPING_AMOUNT=0.00
SHOP_TAX_RATE=0.00
SHOP_TAX_INCLUDED=true

# Archivos académicos. Debe apuntar fuera del directorio público de Atenea.
ACADEMIC_STORAGE_PATH=C:/xampp/atenea-private/academico
ACADEMIC_VIDEO_MAX_MB=250
ACADEMIC_DOCUMENT_MAX_MB=20
ACADEMIC_EVIDENCE_MAX_MB=10
COMMUNICATION_STORAGE_PATH=C:/xampp/atenea-private/comunicaciones

# Copias de base de datos. La ruta debe permanecer fuera del directorio publico.
BACKUP_STORAGE_PATH=C:/xampp/atenea-private/backups
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_FILES=20
# Solo se excluyen los datos temporales; la estructura se conserva en el respaldo.
BACKUP_EXCLUDED_DATA_TABLES=auth_remember_tokens,password_reset_tokens,verificaciones_cuenta,assisted_password_resets,website_preview_tokens,correo_imap_estado

# Correo institucional saliente. Nunca use la contraseña normal; use una contraseña de aplicación.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Atenea
# Destinatario único de contacto y alertas administrativas.
CONTACT_RECIPIENT=

# Seguridad y cola de correo. En pruebas nunca se entrega a usuarios reales.
MAIL_TEST_MODE=true
MAIL_TEST_RECIPIENT=
MAIL_MAX_PER_MINUTE=3
MAIL_MAX_PER_USER_PER_HOUR=5
MAIL_MAX_RETRIES=3
# El newsletter procesa entre 1 y 50 destinatarios por ejecución; se recomienda 25.

# Buzón institucional entrante. Requiere la extensión PHP IMAP.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# DTE. simulation nunca llama a Hacienda. test/production requieren todos los secretos.
DTE_ENV=simulation
DTE_STORAGE_PATH=C:/xampp/atenea-private/dte
COMPROBANTES_STORAGE_PATH=C:/xampp/atenea-private/comprobantes
DTE_NIT=
DTE_NRC=
DTE_HACIENDA_USER=
DTE_HACIENDA_PASSWORD=
DTE_CERTIFICATE_PATH=C:/xampp/atenea-private/certificates/emisor.p12
DTE_CERTIFICATE_SECRET=
DTE_SIGN_URL=
DTE_ACCESS_TOKEN=
DTE_AUTH_URL_TEST=https://apitest.dtes.mh.gob.sv/seguridad/auth
DTE_RECEIVE_URL_TEST=https://apifacturatest.mh.gob.sv/fesv/recepciondte
DTE_QUERY_URL_TEST=https://apifacturatest.mh.gob.sv/fesv/consultadte
DTE_INVALIDATE_URL_TEST=https://apifacturatest.mh.gob.sv/fesv/anulardte
DTE_AUTH_URL_PRODUCTION=https://api.dtes.mh.gob.sv/seguridad/auth
DTE_RECEIVE_URL_PRODUCTION=https://apifactura.mh.gob.sv/fesv/recepciondte
DTE_QUERY_URL_PRODUCTION=https://apifactura.mh.gob.sv/fesv/consultadte
DTE_INVALIDATE_URL_PRODUCTION=https://apifactura.mh.gob.sv/fesv/anulardte

# Produccion: APP_URL_PRODUCTION debe ser la URL HTTPS real, con su subcarpeta si existe.
# APP_ENV=production
